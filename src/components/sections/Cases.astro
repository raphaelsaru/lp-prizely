---
import Badge from '../ui/Badge.astro';
import CaseCarousel from '../react/CaseCarousel';
import { User, Quote } from 'lucide-react';
---

<section id="cases" class="section bg-slate-50">
  <div class="container">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <Badge variant="primary" size="lg" class="mb-4">
        Cases de Sucesso
      </Badge>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-slate-900 mb-6">
        Resultados que <span class="gradient-text">falam por si</span>
      </h2>
      <p class="text-xl text-slate-600">
        Veja como ajudamos empresas de diversos setores a alcançarem crescimento exponencial.
      </p>
    </div>

    <!-- Carousel -->
    <div class="max-w-7xl mx-auto mb-16">
      <CaseCarousel client:visible />
    </div>

    <!-- Client Logos -->
    <div class="max-w-5xl mx-auto">
      <p class="text-center text-slate-500 text-sm mb-8 font-medium uppercase tracking-wide">
        Empresas que confiam na Prizely
      </p>
      <div class="flex flex-wrap justify-center items-center gap-12 opacity-60">
        <div class="text-2xl font-bold text-slate-700">Empresa A</div>
        <div class="text-2xl font-bold text-slate-700">Empresa B</div>
        <div class="text-2xl font-bold text-slate-700">Empresa C</div>
        <div class="text-2xl font-bold text-slate-700">Empresa D</div>
        <div class="text-2xl font-bold text-slate-700">Empresa E</div>
      </div>
    </div>

    <!-- Testimonial -->
    <div class="max-w-4xl mx-auto mt-16">
      <div class="relative rounded-2xl bg-white p-8 md:p-12 shadow-xl">
        <!-- Quote Icon -->
        <div class="absolute top-0 left-8 transform -translate-y-1/2">
          <div class="w-16 h-16 bg-gradient-primary rounded-full flex items-center justify-center">
            <Quote className="w-8 h-8 text-white" />
          </div>
        </div>

        <!-- Testimonial Content -->
        <div class="pt-8">
          <p class="text-lg md:text-xl text-slate-700 leading-relaxed mb-6 italic">
            "A Prizely transformou completamente nossa estratégia de marketing digital. Em menos de 6 meses, nosso faturamento triplicou e finalmente temos previsibilidade nas vendas. A equipe é extremamente profissional e os resultados falam por si."
          </p>
          <div class="flex items-center">
            <div class="w-12 h-12 bg-gradient-primary rounded-full flex items-center justify-center mr-4">
              <User className="w-6 h-6 text-white" />
            </div>
            <div>
              <div class="font-semibold text-slate-900">João Pedro Silva</div>
              <div class="text-sm text-slate-600">CEO, TechStart Brasil</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

