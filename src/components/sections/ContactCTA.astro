---
import ContactForm from '../react/ContactForm';
import { CheckCircle, Lock, Zap, Target } from 'lucide-react';
---

<section id="contato" class="section bg-gradient-to-br from-slate-900 via-primary-900 to-slate-900 text-white relative overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-500 rounded-full mix-blend-multiply filter blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary-500 rounded-full mix-blend-multiply filter blur-3xl"></div>
  </div>

  <div class="container relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold mb-6">
          Pronto para transformar seu <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-300 to-secondary-300">investimento em resultados</span>?
        </h2>
        <p class="text-xl text-slate-300 mb-8 leading-relaxed">
          Preencha o formulário ao lado e dê o primeiro passo rumo ao crescimento que seu negócio merece.
        </p>

        <!-- Benefits -->
        <div class="space-y-4 mb-8">
          <div class="flex items-start space-x-3">
            <CheckCircle className="w-6 h-6 text-accent-400 flex-shrink-0 mt-1" />
            <div>
              <h3 class="font-semibold text-lg">Diagnóstico Gratuito</h3>
              <p class="text-slate-400">Análise inicial das suas campanhas e oportunidades sem custo</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <CheckCircle className="w-6 h-6 text-accent-400 flex-shrink-0 mt-1" />
            <div>
              <h3 class="font-semibold text-lg">Resposta em 24h</h3>
              <p class="text-slate-400">Nossa equipe entrará em contato rapidamente</p>
            </div>
          </div>
          <div class="flex items-start space-x-3">
            <CheckCircle className="w-6 h-6 text-accent-400 flex-shrink-0 mt-1" />
            <div>
              <h3 class="font-semibold text-lg">Sem Compromisso</h3>
              <p class="text-slate-400">Conheça nossa proposta antes de tomar qualquer decisão</p>
            </div>
          </div>
        </div>

        <!-- Trust Badges -->
        <div class="flex flex-wrap gap-4">
          <div class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg border border-white/20">
            <div class="flex items-center space-x-2">
              <Lock className="w-5 h-5 text-white" />
              <span class="text-sm font-medium">Dados Protegidos</span>
            </div>
          </div>
          <div class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg border border-white/20">
            <div class="flex items-center space-x-2">
              <Zap className="w-5 h-5 text-white" />
              <span class="text-sm font-medium">Resposta Rápida</span>
            </div>
          </div>
          <div class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg border border-white/20">
            <div class="flex items-center space-x-2">
              <Target className="w-5 h-5 text-white" />
              <span class="text-sm font-medium">Sem Spam</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Form -->
      <div class="bg-white rounded-2xl p-8 shadow-2xl">
        <div class="mb-6">
          <h3 class="text-2xl font-heading font-bold text-slate-900 mb-2">
            Fale com um Especialista
          </h3>
          <p class="text-slate-600">
            Preencha os campos abaixo e nossa equipe entrará em contato.
          </p>
        </div>
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</section>

