---
import { neon } from '@neondatabase/serverless';

const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD ?? 'prizely2025';

let leads: any[] = [];
let authError = false;
let isAuthenticated = false;

const method = Astro.request.method;

if (method === 'POST') {
  const form = await Astro.request.formData();
  const senha = form.get('senha')?.toString() ?? '';
  if (senha === ADMIN_PASSWORD) {
    isAuthenticated = true;
  } else {
    authError = true;
  }
}

if (isAuthenticated) {
  try {
    const sql = neon(import.meta.env.DATABASE_URL);
    leads = await sql`SELECT * FROM leads ORDER BY created_at DESC LIMIT 500`;
  } catch (e) {
    leads = [];
  }
}

const formatDate = (d: string) =>
  new Date(d).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo', day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit' });

const painLabel: Record<string, string> = {
  processos: 'Processos manuais',
  atendimento: 'Atendimento',
  produtividade: 'Produtividade',
  conhecimento: 'Gestão conhecimento',
  dados: 'Análise de dados',
  outro: 'Outro',
};

const budgetLabel: Record<string, string> = {
  'nao-sei': 'Ainda não sabe',
  'ate-2k': 'Até R$ 2k',
  '2k-5k': 'R$ 2k–5k',
  'acima-5k': 'Acima R$ 5k',
};
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leads — Prizely Admin</title>
  <meta name="robots" content="noindex,nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }

    .login-wrap {
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; padding: 1rem;
    }
    .login-card {
      background: #1e293b; border: 1px solid #334155; border-radius: 16px;
      padding: 2.5rem; width: 100%; max-width: 360px;
    }
    .login-card h1 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.25rem; }
    .login-card p { font-size: 0.85rem; color: #94a3b8; margin-bottom: 1.5rem; }
    .login-card input {
      width: 100%; padding: 0.75rem 1rem; border-radius: 8px;
      border: 1px solid #334155; background: #0f172a; color: #e2e8f0;
      font-size: 0.95rem; margin-bottom: 1rem; outline: none;
    }
    .login-card input:focus { border-color: #6366f1; }
    .btn-primary {
      width: 100%; padding: 0.75rem; border-radius: 8px; border: none;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: white; font-weight: 600; cursor: pointer; font-size: 0.95rem;
    }
    .error { color: #f87171; font-size: 0.8rem; margin-top: 0.5rem; }

    .admin-wrap { padding: 1.5rem; max-width: 1400px; margin: 0 auto; }
    .admin-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: gap; gap: 1rem; }
    .admin-header h1 { font-size: 1.25rem; font-weight: 700; }
    .badge { background: #1e293b; border: 1px solid #334155; border-radius: 999px; padding: 0.25rem 0.75rem; font-size: 0.75rem; color: #94a3b8; }

    .table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid #1e293b; }
    table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    thead { background: #1e293b; }
    th { padding: 0.65rem 0.75rem; text-align: left; font-weight: 600; color: #94a3b8; white-space: nowrap; }
    td { padding: 0.65rem 0.75rem; border-top: 1px solid #1e293b; vertical-align: top; }
    tr:hover td { background: #1e293b55; }
    .source-badge {
      display: inline-block; padding: 0.2rem 0.5rem; border-radius: 999px;
      font-size: 0.7rem; font-weight: 600; background: #4f46e520; color: #818cf8;
      border: 1px solid #4f46e540;
    }
    .source-google { background: #16a34a20; color: #4ade80; border-color: #16a34a40; }
    .source-meta { background: #1d4ed820; color: #60a5fa; border-color: #1d4ed840; }
    .empty { text-align: center; padding: 3rem; color: #475569; }
    a.back { color: #94a3b8; font-size: 0.8rem; text-decoration: none; }
    a.back:hover { color: #e2e8f0; }

    .export-btn {
      padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid #334155;
      background: transparent; color: #94a3b8; cursor: pointer; font-size: 0.8rem;
    }
    .export-btn:hover { background: #1e293b; color: #e2e8f0; }
  </style>
</head>
<body>

{!isAuthenticated ? (
  <div class="login-wrap">
    <div class="login-card">
      <h1>Prizely Admin</h1>
      <p>Acesso restrito — leads do formulário</p>
      <form method="POST">
        <input type="password" name="senha" placeholder="Senha" autofocus required />
        {authError && <p class="error">Senha incorreta.</p>}
        <button type="submit" class="btn-primary">Entrar</button>
      </form>
    </div>
  </div>
) : (
  <div class="admin-wrap">
    <div class="admin-header">
      <div>
        <h1>Leads</h1>
        <span class="badge">{leads.length} registros</span>
      </div>
      <div style="display:flex;gap:0.75rem;align-items:center;">
        <button class="export-btn" onclick="exportCSV()">⬇ Exportar CSV</button>
        <a href="/" class="back">← Voltar ao site</a>
      </div>
    </div>

    {leads.length === 0 ? (
      <div class="empty">Nenhuma lead ainda. Os dados aparecem aqui após o primeiro envio de formulário.</div>
    ) : (
      <div class="table-wrap">
        <table id="leads-table">
          <thead>
            <tr>
              <th>Data</th>
              <th>Nome</th>
              <th>WhatsApp</th>
              <th>E-mail</th>
              <th>Empresa</th>
              <th>Setor</th>
              <th>Funcionários</th>
              <th>Dor principal</th>
              <th>Usa IA?</th>
              <th>Orçamento</th>
              <th>Origem</th>
              <th>Campanha</th>
            </tr>
          </thead>
          <tbody>
            {leads.map((lead) => {
              const source = lead.utm_source || (lead.gclid ? 'google' : lead.fbclid ? 'meta' : '—');
              const sourceClass = source === 'google' ? 'source-badge source-google' : source === 'meta' || source === 'facebook' ? 'source-badge source-meta' : 'source-badge';
              return (
                <tr>
                  <td style="white-space:nowrap;color:#94a3b8;">{formatDate(lead.created_at)}</td>
                  <td style="font-weight:600;">{lead.name}</td>
                  <td>
                    <a href={`https://wa.me/55${lead.whatsapp}`} target="_blank" style="color:#4ade80;text-decoration:none;">
                      {lead.whatsapp}
                    </a>
                  </td>
                  <td style="color:#94a3b8;">{lead.email}</td>
                  <td>{lead.company}</td>
                  <td style="color:#94a3b8;">{lead.sector ?? '—'}</td>
                  <td style="color:#94a3b8;">{lead.employees ?? '—'}</td>
                  <td>{painLabel[lead.pain] ?? lead.pain ?? '—'}</td>
                  <td style="color:#94a3b8;">{lead.uses_ai ?? '—'}</td>
                  <td>{budgetLabel[lead.budget] ?? lead.budget ?? '—'}</td>
                  <td><span class={sourceClass}>{source}</span></td>
                  <td style="color:#94a3b8;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title={lead.utm_campaign ?? ''}>{lead.utm_campaign ?? '—'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>
)}

<script>
function exportCSV() {
  const table = document.getElementById('leads-table');
  if (!table) return;
  const rows = [...table.querySelectorAll('tr')].map(r =>
    [...r.querySelectorAll('th,td')].map(c => `"${c.textContent?.trim().replace(/"/g,'""')}"`).join(',')
  );
  const blob = new Blob([rows.join('\n')], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `leads-prizely-${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
}
</script>

</body>
</html>
